osc(15, 0.01, 0.1).modulate(osc(2).rotate(4,1), 20)
osc(100,-0.015,1).pixelate(30).kaleid(()=>(Math.sin(time/8)*9+3)).rotate(0,0.125)
.colorama(10)
.saturate(0.4)
.scale(0.7, 1, 1)
.out()
