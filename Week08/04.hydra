await loadScript("https://cdn.jsdelivr.net/gh/geikha/hyper-hydra@latest/hydra-text.js")
await loadScript("https://hyper-hydra.glitch.me/hydra-text.js")

osc(20, 0.01, 1.1)
.kaleid(6)
.color(1.1,0.35,0.9)
.rotate(0, 0.1)
.modulate(o0, () => mouse.x*0.009)
.scale(1.01)
.out(o0)

hydraText.font = "serif"
hydraText.lineWidth = "10%"
hydraText.fontSize= "155%"
hydraText.textAlign= "left"
hydraText.fillStyle= "white",

str = `1. Reasoning & Context:

-> Why this presentation?
-> Based on reflections and my background:
Standard mini-notation is already an established practice.
However, what may be gained by introducing an AI model in such a context?
-> Framework investigation:
AI Model <-> Model Context Protocol (MCP) <-> Strudel REPL

2. Foundational Research on Live Coding and AI Interaction:

-> https://github.com/williamzujkowski/strudel-mcp-server
-> Identify present and missing musical knowledge in the current
Claude-based MCP (e.g., non-Western scales).Evaluate real-time
interaction and usability, and output complexity.
-> Research Question:How does embedding specific musical knowledge
into the MCP action space improve creativity in real-time Strudel performances?

3. Methodology & Objectives:

-> Comparative Analysis:Claude-based MCP performance across specific parameters
(e.g., pattern complexity and scale variety).
-> Action Space Refinement:Identify parameters to embed in the MCP layer,
bridging natural language intent with musical outcomes.
-> Evaluation:Determine whether Claude-based MCP-generated mini-notation
can be meaningful and complement human compositional habits.
-> Documentation:Record compositions with AI "co-creation"
generated during the research-creation process.
-> AIMC Report 2026 format.

4. Future Directions:

-> Embodied Prompting:Transitioning from typed text to gestural inputs
(facial recognition/body movement) as the primary prompt generator.
-> Model Analysis: Comparing the current Claude-based MCP
with other LLMs such as Codex,or small models trained for real-time co-creation.
 
5. References:
[1]Anna Xambó Sedó. 2021. “Agents in Live Coding: Cibo v2 and Real-Time AI Participation.”
eContact! Journal for Sound and Media 21 (1). https://econtact.ca/21_1/xambosedo_agents.html
[2]Knotts, Shelly, and Iván Paz. 2022. “Live Coding and Machine Learning Is Dangerous: Show
Us Your Algorithms.” Proceedings of the International Conference on Live Coding, Valdivia,
Chile, December 15–17, 2021. Zenodo. https://doi.org/10.5281/zenodo.5888356.
[3]Jouppi, Norm, et al. 2025. “Vibe Coding with Large Language Models: Interactive Prompting
for Creative Code Generation.” ArXiv, February 12, 2025. https://arxiv.org/html/2506.23253v2
Kim, Yewon, Stephen Brade, Alexander Wang, David Zhou, Haven Kim, Bill Wang, Sung-Ju Lee,
[4]Hugo F. Flores Garcia, Cheng-Zhi Anna Huang, and Chris Donahue. 2026. “A Design Space for
Live Music Agents.” arXiv (arXiv:2602.05064).`

// str = `Uandha Fernandes Barbosa, BMus and BSc Eng
//uandha.fernandesbarbosa@mail.concordia.ca`

src(o0)
.layer(text(str).scroll(
()=>0.75-mouse.x/window.innerWidth,
()=>0.5-mouse.y/window.innerHeight))
//.blend(src(o0).scale(1.02).colorama(.07))
//.layer(text(str))
//.diff(strokeText(str).modulateScale(noise(1,1), .4))

.out(o1)

render(o1)
