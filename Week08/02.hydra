//from hydra guide book
shape(7,0.9)
.repeat(15,12)
.invert()
.color(0.3,0,1)
.colorama(23)
.scrollY(0.5,-0.1)
.modulateScale(gradient().g(),5) 
.hue(() => Math.sin(time))
.out()
