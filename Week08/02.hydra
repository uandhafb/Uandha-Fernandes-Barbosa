shape(7,0.9)
.repeat(15,12)
.invert()
.color(0.3,0,1)
.scrollY(0.5,-0.1)
.modulateScale(gradient().g(),5) //from hydra guide book
.contrast( () => Math.sin(time) * 1 )
.hue(() => Math.sin(time))
.out()
