//microscope organic shapes 

osc()
.modulate(noise(1),0.7).scrollX(() => time * 0.01).scrollY(() => time * 0.005)
.modulateRotate(noise(23).rotate(1, 0.2), 3)
.mult(shape(999,0.3,0.001)).scale(2.5, 9/16)
.colorama(13).saturate(0.35)
.out(o0)

src(o0)
.mult(shape(999,()=>Math.sin(time)*0.5+0.9,0.35)
      .scrollX(() => time*0.005+0.35))
.out(o1)
