voronoi(33,3,30).rotate(3,0.3,0)
  .modulateScale(o0,0.5).color(-3,5,0).brightness(3)
  .out(o0)

src(o0).mult(shape(30,0.3,1).invert(({time})=>Math.sin(time)*3))
  .colorama(1).out(o2)
